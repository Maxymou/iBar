# =============================================================================
# iBar - Docker Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.docker.example .env
#
# IMPORTANT: Change all "changeme" values before starting the application.
# =============================================================================

# Application
NODE_ENV=production
PORT=8000

# Database
# DB_HOST must match the postgres service name in docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ibar
DB_USER=ibar_user
DB_PASSWORD=changeme_strong_password

# JWT Authentication
# Generate secure secrets with: openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Public URL (used for CORS - replace with your server IP or domain)
FRONTEND_URL=http://localhost:8000

# Additional CORS origins (comma-separated, optional)
ALLOWED_ORIGINS=

# Adminer port (DB admin web interface)
ADMINER_PORT=9000
