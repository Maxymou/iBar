# Application
NODE_ENV=production
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ibar
DB_USER=ibar_user
DB_PASSWORD=changeme_strong_password

# JWT — générez des secrets sécurisés avec : openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (pour CORS — mettez l'IP ou le domaine public de votre serveur)
# Exemple : FRONTEND_URL=http://192.168.1.100:8000
FRONTEND_URL=http://localhost:8000

# Port Adminer (interface d'administration DB)
ADMINER_PORT=9000

# Credentials pour export-csv.sh (compte utilisateur IBar existant)
EXPORT_EMAIL=
EXPORT_PASSWORD=
