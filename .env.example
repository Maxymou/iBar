# Application
NODE_ENV=production
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ibar
DB_USER=ibar_user
DB_PASSWORD=changeme_strong_password

# JWT — générez des secrets sécurisés avec : openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# URL publique du frontend (utilisée pour le CORS)
# En local       : http://localhost:8000
# Sur un serveur : http://VOTRE_IP:8000 ou https://votre-domaine.com
FRONTEND_URL=http://localhost:8000

# Origines CORS supplémentaires (séparées par des virgules)
# Ajoutez l'IP de votre machine si vous accédez depuis le réseau local
# Exemple : ALLOWED_ORIGINS=http://192.168.1.30:8000,http://mon-serveur.com
ALLOWED_ORIGINS=

# Port Adminer (interface d'administration DB)
ADMINER_PORT=9000

# Credentials pour export-csv.sh (compte utilisateur IBar existant)
EXPORT_EMAIL=
EXPORT_PASSWORD=

# NOTE sur les caractères spéciaux : si une valeur contient '#', '$', etc.,
# entourez-la de guillemets doubles pour éviter une troncature par systemd :
# DB_PASSWORD="mon#mot$de#passe"
