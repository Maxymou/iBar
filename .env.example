# Application
NODE_ENV=production
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ibar
DB_USER=ibar_user
DB_PASSWORD=changeme_strong_password

# JWT
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend URL (for CORS — set to your server's public IP or domain in production)
# Example: FRONTEND_URL=http://192.168.1.100:8000
FRONTEND_URL=http://localhost:8000

# Adminer port (info only, started separately)
ADMINER_PORT=9000

# Export CSV credentials (compte utilisateur existant utilisé par export-csv.sh)
EXPORT_EMAIL=
EXPORT_PASSWORD=
